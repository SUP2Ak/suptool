<Window
    x:Class="ClearTool_WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <NavigationView x:Name="NavView" 
                       SelectionChanged="NavView_SelectionChanged"
                       IsSettingsVisible="True">
            
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Accueil" Tag="HomePage" Icon="Home"/>
                <NavigationViewItem Content="Recherche" Tag="SearchPage" Icon="Find"/>
                <NavigationViewItem Content="Clear Cache" Tag="ClearCachePage" Icon="Delete"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
            
        </NavigationView>
    </Grid>
</Window>