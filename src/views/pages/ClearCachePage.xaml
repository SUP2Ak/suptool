<Page
    x:Class="ClearTool_WinUI.ClearCachePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Zone de recherche -->
        <StackPanel Grid.Row="0" Spacing="10">
            <TextBox x:Name="ExtensionFilter" PlaceholderText="Filtrer par extension"/>
            <Button x:Name="ClearButton" Content="Nettoyer le cache"/>
        </StackPanel>

        <!-- Liste des résultats -->
        <ListView x:Name="ResultsList"
                  Grid.Row="1"
                  SelectionMode="Extended"/>

        <!-- Zone de logs -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Border Background="#FF1E1E1E">
                <TextBlock x:Name="LogTextBlock" 
                          Foreground="White"
                          TextWrapping="Wrap"
                          Padding="10"/>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>